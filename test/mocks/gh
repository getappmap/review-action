#!/usr/bin/env bash
# Mock `gh` CLI for post-review.sh. Logs its arguments to $MOCK_GH_LOG and returns
# canned output. Only the calls post-review.sh makes are handled:
#   gh api repos/O/R/issues/N/comments --paginate --jq '...'  -> echo existing id
#   gh api -X POST  repos/O/R/issues/N/comments   -F body=@f  -> succeed
#   gh api -X PATCH repos/O/R/issues/comments/ID  -F body=@f  -> succeed
set -euo pipefail

[[ -n "${MOCK_GH_LOG:-}" ]] && printf '%s\n' "$*" >> "$MOCK_GH_LOG"

# appmap-js release listing (resolve-versions.sh): canned page with a
# non-appmap release first, then the appmap release with all platform assets.
for a in "$@"; do
  if [[ "$a" == repos/getappmap/appmap-js/releases* ]]; then
    cat <<'EOF'
[{"name":"@appland/scanner-v1.0.0","assets":[]},
 {"name":"@appland/appmap-v9.9.9","tag_name":"@appland/appmap-v9.9.9",
  "assets":[{"name":"appmap-linux-x64"},{"name":"appmap-linux-arm64"},
            {"name":"appmap-macos-x64"},{"name":"appmap-macos-arm64"}]}]
EOF
    exit 0
  fi
done

# A listing call includes --paginate; return the configured existing id (or empty).
for a in "$@"; do
  if [[ "$a" == "--paginate" ]]; then
    printf '%s' "${MOCK_GH_EXISTING_ID:-}"
    exit 0
  fi
done

# POST/PATCH: nothing to emit, just succeed.
exit 0
